# /etc/fstab: YummyOS static file system table.
#
# <file system>         <dir>         <type>    <options>                       <dump> <pass>
UUID=FIXME-UUID-HERE    /             ext4      defaults,noatime,discard        0      1
UUID=FIXME-UUID-EFI     /boot/efi     vfat      defaults,noatime,noauto,nofail  0      2
UUID=FIXME-UUID-SWAP    none          swap      sw,noatime                      0      0

tmpfs                   /tmp          tmpfs     defaults,noatime,nosuid,nodev,size=4G 0 0
