#!/usr/bin/env bash
# YummyOS About - System information, branding, and credits
# Displayed via terminal for quick system identification.

set -euo pipefail

VERSION="1.0.0"
CODENAME="Custard"
BUILD_DATE="2026-01-15"

YUMMYOS_CONF="/etc/yummyos/yummyos.conf"
HOSTNAME=$(hostname 2>/dev/null || echo "yummyos")
KERNEL=$(uname -r 2>/dev/null || echo "unknown")
ARCH=$(uname -m 2>/dev/null || echo "unknown")
UPTIME=$(uptime -p 2>/dev/null || echo "unknown")

get_theme() {
    if [[ -f "$YUMMYOS_CONF" ]]; then
        grep -oP '^theme\s*=\s*\K.*' "$YUMMYOS_CONF" 2>/dev/null || echo "default"
    else
        echo "default"
    fi
}

get_profile() {
    if command -v yummy-performance &>/dev/null; then
        yummy-performance get 2>/dev/null || echo "unknown"
    else
        echo "unknown"
    fi
}

get_de() {
    if [[ -n "${XDG_CURRENT_DESKTOP:-}" ]]; then
        echo "$XDG_CURRENT_DESKTOP"
    elif [[ -n "${DESKTOP_SESSION:-}" ]]; then
        echo "$DESKTOP_SESSION"
    else
        echo "Plasma"
    fi
}

get_shell_info() {
    if [[ -n "${0:-}" ]]; then
        basename "${0}" 2>/dev/null || echo "$SHELL"
    else
        echo "${SHELL:-bash}"
    fi
}

get_terminal() {
    if [[ -n "${TERM_PROGRAM:-}" ]]; then
        echo "$TERM_PROGRAM"
    elif [[ -n "${TERMINAL_EMULATOR:-}" ]]; then
        echo "$TERMINAL_EMULATOR"
    else
        echo "${TERM:-unknown}"
    fi
}

# Colors
BOLD='\033[1m'
DIM='\033[2m'
UNDERLINE='\033[4m'
RESET='\033[0m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'

print_header() {
    echo ""
    echo -e "${BOLD}${CYAN}      _   __                       _  ___  ____  ${RESET}"
    echo -e "${BOLD}${CYAN}     | | / /__  _  ____  _______  | |/ _ \\/ ___| ${RESET}"
    echo -e "${BOLD}${CYAN}     | |/ / _ \\| |/_/ / / / _ \\ | | | | \\___ \\ ${RESET}"
    echo -e "${BOLD}${CYAN}     |   <  __/>  </ /_/ /  __/ | | |_| |___) |${RESET}"
    echo -e "${BOLD}${CYAN}     |_|\\_\\___/_/|_|\\__,_/\\___/ |____/___/____/ ${RESET}"
    echo ""
}

print_version_info() {
    echo -e "  ${BOLD}${WHITE}System:${RESET}  ${HOSTNAME}"
    echo -e "  ${BOLD}${WHITE}OS:${RESET}      YummyOS ${GREEN}${VERSION}${RESET} ${YELLOW}(${CODENAME})${RESET}"
    echo -e "  ${BOLD}${WHITE}Kernel:${RESET}  ${KERNEL}"
    echo -e "  ${BOLD}${WHITE}Arch:${RESET}    ${ARCH}"
    echo -e "  ${BOLD}${WHITE}Desktop:${RESET} $(get_de)"
    echo -e "  ${BOLD}${WHITE}Uptime:${RESET}  ${UPTIME}"
}

print_theme_info() {
    echo ""
    echo -e "  ${BOLD}${MAGENTA}Theme:${RESET}       $(get_theme)"
    echo -e "  ${BOLD}${MAGENTA}Profile:${RESET}     $(get_profile)"
    echo -e "  ${BOLD}${MAGENTA}Terminal:${RESET}    $(get_terminal)"
    echo -e "  ${BOLD}${MAGENTA}Shell:${RESET}       ${SHELL:-/bin/bash}"
}

print_credits() {
    echo ""
    echo -e "  ${DIM}────────────────────────────────────────────${RESET}"
    echo ""
    echo -e "  ${BOLD}${WHITE}Credits:${RESET}"
    echo -e "    ${CYAN}YummyOS Project${RESET} - https://yummyos.org"
    echo -e "    ${GREEN}Core Team:${RESET}"
    echo -e "      Project Lead .............. YummyOS Core"
    echo -e "      Lead Developer ............ YummyOS Dev"
    echo -e "      UX/Design ................. YummyOS Design"
    echo -e "      Packaging ................. YummyOS Package"
    echo ""
    echo -e "    ${GREEN}Special Thanks:${RESET}"
    echo -e "      KDE Plasma Team"
    echo -e "      Arch Linux Community"
    echo -e "      All YummyOS contributors and testers"
    echo ""
    echo -e "  ${DIM}Licensed under GPL-3.0-or-later${RESET}"
    echo -e "  ${DIM}This software comes with ABSOLUTELY NO WARRANTY.${RESET}"
    echo ""
}

print_detailed() {
    echo ""
    echo -e "  ${BOLD}${WHITE}Hardware:${RESET}"
    if [[ -f /proc/cpuinfo ]]; then
        local cpu_model
        cpu_model=$(grep -m1 'model name' /proc/cpuinfo | cut -d: -f2 | xargs 2>/dev/null || echo "unknown")
        echo -e "    CPU:      ${cpu_model}"
    fi
    if command -v free &>/dev/null; then
        local mem_total
        mem_total=$(free -h | awk '/^Mem:/{print $2}' 2>/dev/null || echo "unknown")
        echo -e "    Memory:   ${mem_total}"
    fi
    if [[ -f /proc/meminfo ]]; then
        local mem_avail
        mem_avail=$(free -h | awk '/^Mem:/{print $3}' 2>/dev/null || echo "unknown")
        echo -e "    Used:     ${mem_avail}"
    fi
    if command -v df &>/dev/null; then
        local disk_root
        disk_root=$(df -h / | awk 'NR==2{print $2}' 2>/dev/null || echo "unknown")
        local disk_used
        disk_used=$(df -h / | awk 'NR==2{print $3}' 2>/dev/null || echo "unknown")
        echo -e "    Disk:     ${disk_used} / ${disk_root}"
    fi
    if [[ -f /proc/loadavg ]]; then
        local loadavg
        loadavg=$(cat /proc/loadavg | cut -d' ' -f1-3 2>/dev/null || echo "unknown")
        echo -e "    Load:     ${loadavg}"
    fi
}

# --- Main ---

case "${1:-}" in
    -h|--help)
        echo "Usage: yummy-about [OPTION]"
        echo ""
        echo "Display YummyOS system information, version, and credits."
        echo ""
        echo "Options:"
        echo "  -h, --help       Show this help message"
        echo "  -v, --version    Show version only"
        echo "  -d, --detailed   Show detailed hardware information"
        echo "  --credits        Show credits only"
        echo "  (no arguments)   Show full about screen"
        echo ""
        echo "Version: ${VERSION}"
        exit 0
        ;;
    -V|--version)
        echo "YummyOS ${VERSION} (${CODENAME})"
        exit 0
        ;;
    --credits)
        print_credits
        exit 0
        ;;
    -d|--detailed)
        print_header
        print_version_info
        print_detailed
        print_theme_info
        print_credits
        exit 0
        ;;
    *)
        print_header
        print_version_info
        print_theme_info
        print_credits
        exit 0
        ;;
esac
